{
  "expo": {
    "name": "Sweat-X",
    "slug": "true-fit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.truefit.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you log meals from your gallery.",
          "cameraPermission": "The app accesses your camera to scan and identify food items instantly."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5f7db9fb-6403-4ddc-b1f8-79c3851446ae"
      }
    }
  }
}